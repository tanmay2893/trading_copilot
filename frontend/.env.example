# Optional: override API base (default /api uses Next.js rewrites to the backend).
# If you point at uvicorn directly, include /api (e.g. http://localhost:6700/api).
# NEXT_PUBLIC_API_URL=http://localhost:6700/api

# WebSocket URL for chat. On localhost the UI defaults to ws://localhost:6700 (same as next.config
# /api rewrite target) because Next does not proxy /ws. Override if your API runs on another host/port.
# NEXT_PUBLIC_WS_URL=ws://localhost:6700
